{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "Production-ready API Gateway for microservices — reusable across projects",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --verbose",
    "test:integration": "jest --testPathPatterns=integration --verbose",
    "test:unit": "jest --testPathPatterns=unit --verbose",
    "mock:users": "node mock-services/user-service.js",
    "mock:products": "node mock-services/product-service.js",
    "mock:orders": "node mock-services/order-service.js",
    "mock:all": "node mock-services/user-service.js & node mock-services/product-service.js & node mock-services/order-service.js"
  },
  "keywords": [
    "api-gateway",
    "microservices",
    "proxy",
    "express"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "opossum": "^5.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
