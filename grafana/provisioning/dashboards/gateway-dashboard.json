{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Throughput (requests/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(gateway_http_requests_total[1m])) by (service)", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Median Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(gateway_http_request_duration_seconds_bucket[1m])) by (le, service)) * 1000", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "Active Requests (In-Flight)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(gateway_http_requests_in_flight) by (service)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        { "expr": "gateway_circuit_breaker_state", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED (OK)", "color": "green" }, "1": { "text": "OPEN (FAILED)", "color": "red" }, "2": { "text": "HALF-OPEN", "color": "yellow" } } }
          ]
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "title": "API Gateway Overview",
  "uid": "gateway-overview",
  "version": 1
}
